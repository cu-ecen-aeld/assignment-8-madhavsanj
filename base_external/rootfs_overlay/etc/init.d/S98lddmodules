#!/bin/sh

case "$1" in
start)
echo "S98lddmodules: loading aesdchar, scull, faulty, hello"


# Load modules using modprobe (preferred for Buildroot)
modprobe aesdchar >/dev/null 2>&1 || true
modprobe scull    >/dev/null 2>&1 || true
modprobe faulty   >/dev/null 2>&1 || true
modprobe hello    >/dev/null 2>&1 || true

AESD_MAJOR=$(awk '$2=="aesdchar"{print $1}' /proc/devices)
SCULL_MAJOR=$(awk '$2=="scull"{print $1}' /proc/devices)
FAULTY_MAJOR=$(awk '$2=="faulty"{print $1}' /proc/devices)

if [ -n "$AESD_MAJOR" ] && [ ! -e /dev/aesdchar ]; then
  mknod /dev/aesdchar c "$AESD_MAJOR" 0
fi

if [ -n "$FAULTY_MAJOR" ] && [ ! -e /dev/faulty ]; then
  mknod /dev/faulty c "$FAULTY_MAJOR" 0
fi

if [ -n "$SCULL_MAJOR" ]; then
  i=0
  while [ $i -lt 4 ]; do
    if [ ! -e "/dev/scull$i" ]; then
      mknod "/dev/scull$i" c "$SCULL_MAJOR" $i
    fi
    i=$((i+1))
  done
fi
;;

stop)
echo "S98lddmodules: unloading hello, faulty, scull, aesdchar"

rm -f /dev/aesdchar /dev/faulty /dev/scull0 /dev/scull1 /dev/scull2 /dev/scull3

rmmod hello    >/dev/null 2>&1 || true
rmmod faulty   >/dev/null 2>&1 || true
rmmod scull    >/dev/null 2>&1 || true
rmmod aesdchar >/dev/null 2>&1 || true
;;


restart)
$0 stop
$0 start
;;

*)
echo "Usage: $0 {start|stop|restart}"
exit 1
;;
esac

exit 0
#should see this